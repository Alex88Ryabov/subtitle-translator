{
  "name": "english-course-translator",
  "version": "0.1.0",
  "description": "Chrome extension that translates English course subtitles to Ukrainian/Russian (Udemy, CourseHunter)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@wxt-dev/storage": "^1.2.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@wxt-dev/module-react": "^1.2.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0",
    "wxt": "^0.20.27"
  },
  "overrides": {
    "@vitejs/plugin-react": "5.2.0"
  }
}
